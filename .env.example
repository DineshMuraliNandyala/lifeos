# ── LeetCode Proxy ────────────────────────────────────────────────────────────
# Cloudflare Worker URL (no trailing slash)
NEXT_PUBLIC_LEETCODE_PROXY_URL=https://lifeos-leetcode-proxy.lifeos-leetcode.workers.dev

# ── Google OAuth (for Android step count via Google Fit) ──────────────────────
# 1. Go to console.cloud.google.com
# 2. Create a project → APIs & Services → Enable "Fitness API"
# 3. Credentials → OAuth 2.0 Client ID → Web Application
# 4. Add Authorized redirect URIs: https://your-app.vercel.app/health/callback
# 5. Paste the Client ID below (Client Secret is NOT needed — implicit flow)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── App URL (set in Vercel dashboard automatically, or fill for local) ─────────
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
